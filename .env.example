# Copy to .env and adjust paths if needed. Never commit .env.

# Path to the running bot's results directory and config directory.
# Default assumes POLYMARKET_STREAMING_DASHBOARD is a sibling of BTC_pricer_15m.
RESULTS_DIR=../BTC_pricer_15m/results
CONFIG_DIR=../BTC_pricer_15m

# Dashboard mode: dry_run (read grid state) or live (read single-trader state)
MODE=dry_run

# Default selected instance (rank 4 — aU=1.0 aD=1.3 fU=0.65 fD=0.55 tp=0.3)
DEFAULT_INSTANCE_ID=100

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8799

# Polling cadence (seconds)
POLL_INTERVAL_SECONDS=2
STATE_POLL_INTERVAL_SECONDS=5
LEADERBOARD_POLL_INTERVAL_SECONDS=30
CALIBRATION_TIMEOUT_SECONDS=360

# Docker container name for the live grid bot (used as polymarket price source in grid mode,
# since the grid doesn't write 15m_orderbook.csv). Empty string disables this fallback.
DOCKER_CONTAINER=btc_pricer_15m_grid
DOCKER_POLL_INTERVAL_SECONDS=3

# Logging
LOG_LEVEL=INFO
